<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page_title ? "#{h(page_title)} | #{h(SITE_TITLE)}" : h(SITE_TITLE) %></title>
  <style>
<%= base_css %>

/* Shared browse page styles */

.browse-header {
  margin-bottom: 2rem;
}

.browse-header p {
  color: #666;
  font-size: 1rem;
  margin-top: 0.5rem;
  text-indent: 0;
}

.book-title a {
  color: #62708d;
  text-decoration: none;
  font-weight: 600;
}

.book-title a:hover {
  text-decoration: underline;
}

.book-meta {
  margin-top: 0.2rem;
}

.book-pub {
  font-style: italic;
  color: #777;
}

.public-badge {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: bold;
  text-transform: uppercase;
  color: #3a3f44;
  background: #e9ecef;
  border: 1px solid #ced4da;
  border-radius: 3px;
  padding: 0.15em 0.45em;
  vertical-align: middle;
  margin-left: 0.2rem;
  white-space: nowrap;
}

.book-list-cover {
  width: 150px;
  aspect-ratio: 2 / 3;
  object-fit: cover;
  border-radius: 4px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  flex-shrink: 0;
  align-self: flex-start;
  display: block;
}

<%= page_css %>

/* Browse filter */

[hidden] { display: none !important; }

.browse-filter {
  border: 1px solid #dee2e6;
  border-radius: 6px;
  padding: 0.5rem 1rem;
  margin-bottom: 1.5rem;
  display: inline-flex;
  align-items: center;
  gap: 1.25rem;
  flex-wrap: wrap;
}

.browse-filter legend {
  float: left;
  font-weight: 600;
  font-size: 0.9rem;
}

.browse-filter label {
  cursor: pointer;
  font-size: 0.9rem;
}

.alpha-nav__inactive {
  opacity: 0.35;
  pointer-events: none;
}
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="brand-container">
        <h1 class="brand"><%= h(BRAND_NAME) %></h1>
      </div>
      <nav class="main-nav">
        <ul>
          <li><a href="<%= base_path %>index.html">Home</a></li>
          <li><a href="<%= base_path %>browse_subject.html">Browse by Subject</a></li>
          <li><a href="<%= base_path %>browse_title.html">Browse by Title</a></li>
          <li><a href="<%= base_path %>about.html">About</a></li>
        </ul>
      </nav>
    </div>
  </header>

<%= page_content %>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-links">
        <a href="<%= base_path %>help.html">Help</a>
        <a href="https://cdlib.org/about/policies-and-guidelines/privacy-statement/">Privacy Policy</a>
        <a href="https://cdlib.org/about/policies-and-guidelines/accessibility/">Accessibility Statement</a>
      </div>
      <p>
        <%= h(BRAND_NAME) %> is a joint publication of the <a href="https://cdlib.org">California Digital Library</a> and <a href="https://ucpress.edu">University of California Press</a>.
      </p>
      <p>&copy; 2025 The Regents of the University of California</p>
    </div>
  </footer>
<% if page_js && !page_js.empty? -%>
  <script><%= page_js %></script>
<% end -%>
</body>
</html>
