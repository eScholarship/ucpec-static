  <main class="document-content" id="top">
    <div class="container">
      <div class="browse-header">
        <h1><%= h(page_title) %></h1>
        <p><%= current_books.size %> titles. Jump to a letter or scroll to browse.</p>
      </div>

      <nav class="alpha-nav" aria-label="Alphabetical navigation">
        <% all_letters.each do |letter| -%>
        <% if active_letters.include?(letter) -%>
        <a href="#letter-<%= letter %>"><%= letter %></a>
        <% else -%>
        <span aria-hidden="true"><%= letter %></span>
        <% end -%>
        <% end -%>
      </nav>

      <% books_by_letter.each do |letter, books_in_section| -%>
      <section class="letter-section" id="letter-<%= letter %>">
        <h2><%= h(letter) %></h2>
        <ul class="book-list">
          <% books_in_section.each do |book| -%>
          <li>
            <div class="book-title">
              <a href="<%= book_url(book["ark"]) %>"><%= h(book["title"]) %></a>
            </div>
            <div class="book-meta">
              <% if book["author"] && !book["author"].empty? -%>
              <%= h(book["author"]) %>
              <% end -%>
              <% info = pub_info(book) -%>
              <% unless info.empty? -%>
              &mdash; <span class="book-pub"><%= h(info) %></span>
              <% end -%>
            </div>
          </li>
          <% end -%>
        </ul>
        <a href="#top" class="back-to-top">&#8593; Back to top</a>
      </section>
      <% end -%>
    </div>
  </main>
