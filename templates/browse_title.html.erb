<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= h(page_title) %> | <%= h(SITE_TITLE) %></title>
  <style>
<%= base_css %>

/* Browse by Title */

.browse-header {
  margin-bottom: 2rem;
}

.browse-header p {
  color: #666;
  font-size: 1rem;
  margin-top: 0.5rem;
  text-indent: 0;
}

.alpha-nav {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0.25rem;
  margin: 1.5rem 0 2rem;
  padding: 1rem 1.25rem;
  background: #f8f9fa;
  border: 1px solid #dee2e6;
  border-radius: 6px;
}

.alpha-nav a,
.alpha-nav span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.1rem;
  height: 2.1rem;
  border-radius: 4px;
  font-weight: 600;
  text-decoration: none;
}

.alpha-nav a {
  color: #62708d;
  background: #e2e6f0;
}

.alpha-nav a:hover {
  background: #62708d;
  color: #fff;
}

.alpha-nav span {
  color: #ccc;
  cursor: default;
}

.letter-section {
  margin-top: 2.5rem;
}

.letter-section h2 {
  border-bottom: 2px solid #dee2e6;
  color: #62708d;
}

.book-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.book-list li {
  padding: 0.65rem 0;
  border-bottom: 1px solid #f0f0f0;
}

.book-list li:last-child {
  border-bottom: none;
}

.book-title a {
  color: #62708d;
  text-decoration: none;
  font-weight: 600;
}

.book-title a:hover {
  text-decoration: underline;
}

.book-meta {
  margin-top: 0.15rem;
}

.book-pub {
  font-style: italic;
  color: #777;
}

.back-to-top {
  display: inline-block;
  margin-top: 2rem;
  font-size: 0.85rem;
  color: #62708d;
  text-decoration: none;
}

.back-to-top:hover {
  text-decoration: underline;
}

@media (max-width: 768px) {
  .alpha-nav {
    gap: 0.2rem;
    padding: 0.75rem;
  }

  .alpha-nav a,
  .alpha-nav span {
    width: 1.9rem;
    height: 1.9rem;
    font-size: 0.85rem;
  }

  .letter-section h2 {
    font-size: 1.5rem;
  }
}
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div>
        <h1 class="brand"><%= h(BRAND_NAME) %></h1>
        <div class="tagline">formerly eScholarship Editions</div>
      </div>
      <nav class="main-nav">
        <ul>
          <li><a href="index.html">Home</a></li>
          <li><a href="browse_subject_public.html">Browse by Subject</a></li>
          <li><a href="browse_title_public.html">Browse by Title</a></li>
          <li><a href="about.html">About</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main class="document-content" id="top">
    <div class="container">
      <div class="browse-header">
        <h1><%= h(page_title) %></h1>
        <p><%= current_books.size %> titles. Jump to a letter or scroll to browse.</p>
      </div>

      <nav class="alpha-nav" aria-label="Alphabetical navigation">
        <% all_letters.each do |letter| -%>
        <% if active_letters.include?(letter) -%>
        <a href="#letter-<%= letter %>"><%= letter %></a>
        <% else -%>
        <span aria-hidden="true"><%= letter %></span>
        <% end -%>
        <% end -%>
      </nav>

      <% books_by_letter.each do |letter, books_in_section| -%>
      <section class="letter-section" id="letter-<%= letter %>">
        <h2><%= h(letter) %></h2>
        <ul class="book-list">
          <% books_in_section.each do |book| -%>
          <li>
            <div class="book-title">
              <a href="<%= book_url(book["ark"]) %>"><%= h(book["title"]) %></a>
            </div>
            <div class="book-meta">
              <% if book["author"] && !book["author"].empty? -%>
              <%= h(book["author"]) %>
              <% end -%>
              <% info = pub_info(book) -%>
              <% unless info.empty? -%>
              &mdash; <span class="book-pub"><%= h(info) %></span>
              <% end -%>
            </div>
          </li>
          <% end -%>
        </ul>
        <a href="#top" class="back-to-top">&#8593; Back to top</a>
      </section>
      <% end -%>
    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-links">
        <a href="privacy.html">Privacy Policy</a>
        <a href="terms.html">Terms of Use</a>
        <a href="contact.html">Contact</a>
        <a href="help.html">Help</a>
      </div>
      <p><%= h(BRAND_NAME) %> is a joint publication of the <a href="https://cdlib.org">California Digital Library</a> and <a href="https://ucpress.edu">University of California Press</a>.</p>
      <p>&copy; 2025 The Regents of the University of California</p>
    </div>
  </footer>
</body>
</html>
